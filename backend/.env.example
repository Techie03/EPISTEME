# Episteme Backend Environment Variables

# Server Config
PORT=8000
HOST=0.0.0.0

# NVIDIA NIM API (Core LLM & Embeddings)
# Get key from: https://build.nvidia.com/
NVIDIA_API_KEY=your_nvidia_nim_api_key_here

# Supabase (Database, Auth, Paper Cache)
# Get credentials from your Supabase Project Settings -> API
SUPABASE_URL=your_supabase_url_here
SUPABASE_KEY=your_supabase_anon_or_service_key_here

# Qdrant Cloud (Vector Database)
# Get cluster URL and API key from Qdrant Cloud Console
QDRANT_URL=your_qdrant_cluster_url_here
QDRANT_API_KEY=your_qdrant_api_key_here

# Upstash Redis (Caching & Rate Limiting)
# Get URL and Token from Upstash Console
UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here
